{
  "compilerOptions": {
    "target":                   "ESNext",
    "module":                   "ESNext",
    "moduleResolution":         "bundler",
    "lib":                      ["ESNext"],
    "types":                    ["bun-types"],
    "strict":                   true,
    "skipLibCheck":             true,
    "noEmit":                   true,
    "allowImportingTsExtensions": true,
    "esModuleInterop":          true,
    "resolveJsonModule":        true,
    "outDir":                   "dist"
  },
  "include":  ["src/**/*", "build.ts"],
  "exclude":  ["node_modules", "dist", "volumes", "backups", "logs"]
}
